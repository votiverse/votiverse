{
  "name": "votiverse",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild", "better-sqlite3"]
  },
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "lint": "eslint packages/*/src/",
    "format": "prettier --write 'packages/*/src/**/*.ts' 'packages/*/tests/**/*.ts'",
    "format:check": "prettier --check 'packages/*/src/**/*.ts' 'packages/*/tests/**/*.ts'",
    "clean": "pnpm -r clean"
  },
  "devDependencies": {
    "eslint": "^9.27.0",
    "@eslint/js": "^9.27.0",
    "typescript-eslint": "^8.57.0",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3"
  }
}
