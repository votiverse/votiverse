{
  "name": "@votiverse/engine",
  "version": "0.1.0",
  "description": "Orchestration layer wiring all Votiverse packages into a coherent runtime",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist",
    "lint": "eslint src/"
  },
  "dependencies": {
    "@votiverse/core": "workspace:*",
    "@votiverse/config": "workspace:*",
    "@votiverse/identity": "workspace:*",
    "@votiverse/delegation": "workspace:*",
    "@votiverse/voting": "workspace:*",
    "@votiverse/prediction": "workspace:*",
    "@votiverse/polling": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
