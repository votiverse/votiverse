{
  "name": "@votiverse/vcp",
  "version": "0.1.0",
  "private": true,
  "description": "Votiverse Cloud Platform — governance-as-a-service backend",
  "type": "module",
  "main": "./dist/main.js",
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/main.ts",
    "seed": "tsx scripts/seed.ts",
    "reset": "tsx scripts/reset.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@votiverse/engine": "workspace:*",
    "@votiverse/core": "workspace:*",
    "@votiverse/config": "workspace:*",
    "@votiverse/identity": "workspace:*",
    "@votiverse/delegation": "workspace:*",
    "@votiverse/voting": "workspace:*",
    "@votiverse/prediction": "workspace:*",
    "@votiverse/polling": "workspace:*",
    "@votiverse/awareness": "workspace:*",
    "hono": "^4.7.0",
    "@hono/node-server": "^1.14.0",
    "better-sqlite3": "^11.9.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.15.0",
    "tsup": "^8.5.1",
    "tsx": "^4.19.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
