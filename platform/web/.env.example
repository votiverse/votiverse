# Votiverse Web Client — Environment Variables
#
# Copy this file to .env.local and adjust values for your environment.
# Variables prefixed with VITE_ are available in client-side code.

# VCP API base URL. In dev mode, "/api" is proxied to localhost:3000.
# In production, set to the full VCP URL (e.g., https://api.example.com).
VITE_API_BASE_URL=/api

# VCP API key for authentication.
VITE_API_KEY=vcp_dev_key_00000000
